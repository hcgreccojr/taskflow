# Usado pelo docker-compose (rede interna dos containers).
# Para rodar comandos do Prisma CLI direto na sua máquina (fora do container),
# use backend/.env.example (hostname localhost em vez de postgres).

# PostgreSQL (usado pelo serviço postgres do docker-compose)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# Backend (hostname "postgres" = nome do serviço na rede do docker-compose)
DATABASE_URL=postgresql://taskflow:taskflow@postgres:5432/taskflow?schema=public
PORT=3000
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend
VITE_API_URL=http://localhost:3000
