# Para rodar o Prisma CLI (migrate, generate) ou `npm run start:dev` direto na
# sua máquina, com o postgres do docker-compose exposto em localhost:5432.
DATABASE_URL=postgresql://taskflow:taskflow@localhost:5432/taskflow?schema=public
PORT=3000
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
